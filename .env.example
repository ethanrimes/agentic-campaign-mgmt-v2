# agentic-campaign-mgmt-v2/.env

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# Encryption Key (REQUIRED for token security)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-generated-encryption-key

# OpenAI API Key (Required by default)
OPENAI_API_KEY=sk-proj-...
AD_ACCOUNT_ID=your-ad-account-id

# Meta (Facebook/Instagram) API
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
LONG_LIVED_USER_ACCESS_TOKEN=your-long-lived-user-access-token
# Optional Meta secrets
# FACEBOOK_PAGE_ID=your-page-id
# APP_USERS_INSTAGRAM_ACCOUNT_ID=your-instagram-account-id
# FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
# INSTAGRAM_PAGE_ACCESS_TOKEN=your-instagram-page-access-token
# INSTAGRAM_ACCOUNT_ID=your-instagram-account-id
# USER_ID=your-user-id

FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Business asset IDs for content actions (creation, planning, verification, publishing, comments)
BUSINESS_ASSETS=asset1,asset2
# Business asset IDs for metrics/insights gathering (can be different accounts)
METRICS_BUSINESS_ASSETS=asset1,asset2

MARKETING_API_KEY=your-marketing-api-key

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Direct Postgres connection string (optional; used for raw SQL/admin migrations)
# SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Additional AI Model API Keys (Optional - choose based on your model provider)
GEMINI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...

# Wavespeed AI API Key (Required for AI-generated images/videos)
WAVESPEED_API_KEY=your-wavespeed-api-key

# RapidAPI Key (Required for social media scraping)
RAPIDAPI_KEY=your-rapidapi-key

# =============================================================================
# APPLICATION SETTINGS (Optional - defaults provided)
# =============================================================================

# Model Provider Selection
# Options: "openai", "gemini", "anthropic"
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-5.4

# Content Generation Limits (Guardrails)
# Target: 4-5 content pieces/day, 3 being videos (each piece cross-posts IG + FB)
MIN_POSTS_PER_DAY=8
MAX_POSTS_PER_DAY=10
MIN_CONTENT_SEEDS_PER_DAY=2
MAX_CONTENT_SEEDS_PER_DAY=5
MIN_VIDEOS_PER_DAY=3
MAX_VIDEOS_PER_DAY=4
MIN_IMAGES_PER_DAY=1
MAX_IMAGES_PER_DAY=2

# Wavespeed AI Configuration
WAVESPEED_IMAGE_MODEL="x-ai/grok-imagine-image/text-to-image"
# x-ai/grok-imagine-image/text-to-image
# bytedance/seedream-v4.5
# bytedance/seedream-v4
# stability-ai/sdxl-lora
WAVESPEED_VIDEO_MODEL="x-ai/grok-imagine-video/text-to-video"
# x-ai/grok-imagine-video/text-to-video
# bytedance/seedance-v1-pro-t2v-480p
# wavespeed-ai/wan-2.2/t2v-5b-720p
WAVESPEED_API_BASE="https://api.wavespeed.ai/api/v3"
WAVESPEED_POLLING_INTERVAL=2.0
WAVESPEED_MAX_POLL_ATTEMPTS=1200

# Publishing Schedule (hours between checks)
PUBLISHING_CHECK_INTERVAL=5

# Logging
LOG_LEVEL=INFO

# Langsmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=your-langsmith-project
